<IfModule mod_rewrite.c>
  # Default file(s) to serve for directories
  DirectoryIndex index.php index.html

  RewriteEngine On
  RewriteBase /

  # 1) If the request maps to a real file or directory—serve it directly.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # 2) Otherwise, rewrite into public/ (your Laravel front controller)
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
