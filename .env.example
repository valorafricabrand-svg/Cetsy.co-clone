APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
AUTH_VERIFICATION_EXPIRE=1440
SELLER_SIGNUP_AUTO_APPROVE=true

# Tailwind migration toggle (main theme layout)
LEGACY_BOOTSTRAP_COMPAT=true

# Public support & compliance (set for Stripe/marketplace reviews)
SUPPORT_EMAIL=support@yourdomain.com
SUPPORT_PHONE=+254700000000
SUPPORT_ADDRESS=
OPERATING_COUNTRY=Kenya
LEGAL_JURISDICTION=Kenya

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# PayPal Payouts
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=
PAYPAL_WEBHOOK_ID=

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Paystack
PAYSTACK_PUBLIC_KEY=
PAYSTACK_SECRET_KEY=

# Wise
WISE_API_TOKEN=
WISE_PROFILE_ID=

# Tawk.to live chat
TAWK_TO_EMBED_URL=

# Safaricom Daraja (M-Pesa)
SAFARICOM_DARAJA_BASE_URL=
SAFARICOM_SHORTCODE=
SAFARICOM_PASSKEY=
SAFARICOM_INITIATOR_NAME=
SecurityCredential=
SAFARICOM_B2C_TIMEOUT_URL=${APP_URL}/daraja/b2c/timeout
SAFARICOM_B2C_RESULT_URL=${APP_URL}/daraja/b2c/result
SAFARICOM_STK_CALLBACK_URL=${APP_URL}/wallet/deposit/mpesa/callback
SAFARICOM_BALANCE_TIMEOUT_URL=${APP_URL}/daraja/balance/timeout
SAFARICOM_BALANCE_RESULT_URL=${APP_URL}/daraja/balance/result

# ------------------------------------------------------------
# SKU duplication strategy for product duplicates
# - append: keep original and append -{SUFFIX}-{RANDOM}
# - clear:  clear SKUs on the duplicate
# - keep:   copy SKUs verbatim (may clash)
DUPLICATE_SKU_STRATEGY=append
DUPLICATE_SKU_SUFFIX=DUP
DUPLICATE_SKU_RANDOM_LEN=4
# Fee applied when releasing on-hold funds to available (percent)
HOLD_RELEASE_FEE_PERCENT=5.5
